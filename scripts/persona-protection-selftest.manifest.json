{
  "version": 1,
  "name": "persona-protection-selftest",
  "description": "Unified self-test net for Persona Baseline Guardian (backend + frontend + architecture guards).",
  "layers": {
    "architecture": {
      "label": "Architecture guard",
      "runner": "node",
      "targets": [
        "tests/architecture/persona-protection-selftest-net.test.js"
      ]
    },
    "backend": {
      "label": "Backend integration",
      "runner": "pytest",
      "module": "tests/integration/security/test_integrity_protection.py",
      "targets": [
        "test_persona_disabled_no_startup_scan",
        "test_persona_disable_reenable_lifecycle",
        "test_persona_disabled_agent_write_silent",
        "test_persona_put_rejects_targets_when_disabled",
        "test_persona_offline_tamper_startup_scan",
        "test_operator_editor_save_implicit_accept",
        "test_agent_write_persona_drift",
        "test_persona_watch_triggers_check_on_modify",
        "test_persona_drift_alert_restore_accept",
        "test_persona_restore_rejects_wrong_phrase"
      ]
    },
    "frontend": {
      "label": "Console frontend",
      "runner": "vitest",
      "cwd": "console",
      "targets": [
        "src/extension/persona_baseline/api/client.test.ts",
        "src/extension/persona_baseline/lib/alertActions.test.ts",
        "src/extension/persona_baseline/lib/driftAlertItems.test.ts",
        "src/extension/persona_baseline/lib/navigation.test.ts",
        "src/extension/persona_baseline/hooks/usePersonaDriftWatch.test.ts",
        "src/pages/Settings/Security/components/IntegrityCheckSection.test.tsx",
        "src/pages/Settings/Security/useSecurityPage.persona.test.tsx",
        "src/pages/Inbox/hooks/useInboxData.persona.test.ts"
      ]
    }
  },
  "scenarios": [
    { "id": "PB-S02", "layer": "backend", "target": "test_persona_disabled_no_startup_scan" },
    { "id": "PB-S10", "layer": "backend", "target": "test_persona_disable_reenable_lifecycle" },
    { "id": "PB-S11", "layer": "backend", "target": "test_persona_disable_reenable_lifecycle" },
    { "id": "PB-S12", "layer": "backend", "target": "test_persona_disable_reenable_lifecycle" },
    { "id": "PB-S13", "layer": "backend", "target": "test_persona_disable_reenable_lifecycle" },
    { "id": "PB-S15", "layer": "backend", "target": "test_persona_disabled_agent_write_silent" },
    { "id": "PB-S16", "layer": "backend", "target": "test_persona_put_rejects_targets_when_disabled" },
    { "id": "PB-S20", "layer": "backend", "target": "test_persona_offline_tamper_startup_scan" },
    { "id": "PB-S30", "layer": "backend", "target": "test_agent_write_persona_drift" },
    { "id": "PB-S40", "layer": "backend", "target": "test_operator_editor_save_implicit_accept" },
    { "id": "PB-S42", "layer": "backend", "target": "test_persona_drift_alert_restore_accept" },
    { "id": "PB-S43", "layer": "backend", "target": "test_persona_restore_rejects_wrong_phrase" },
    { "id": "PB-S44", "layer": "backend", "target": "test_persona_drift_alert_restore_accept" },
    { "id": "PB-S50", "layer": "backend", "target": "test_persona_watch_triggers_check_on_modify" },
    { "id": "PB-S01", "layer": "frontend", "target": "IntegrityCheckSection.test.tsx" },
    { "id": "PB-SUI-NOTIFIER", "layer": "frontend", "target": "personaAlertActions.test.ts" },
