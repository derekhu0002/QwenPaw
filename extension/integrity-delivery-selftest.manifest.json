{
  "version": 1,
  "name": "integrity-delivery-selftest",
  "description": "Unified self-test net for all Integrity Protection deliveries (rule integrity, persona baseline, health check).",
  "console_gate": {
    "typecheck": {
      "label": "Console tsc + vite build",
      "cwd": "console",
      "command": "npm run build"
    }
  },
  "deliveries": [
    {
      "id": "rule-integrity",
      "label": "Built-in tool rule integrity",
      "manifest": "extension/rule-integrity-selftest.manifest.json"
    },
    {
      "id": "persona-protection",
      "label": "Persona Baseline Guardian",
      "manifest": "scripts/persona-protection-selftest.manifest.json"
    },
    {
      "id": "health-check",
      "label": "Integrity Protection Health Check",
      "manifest": "scripts/health-check-selftest.manifest.json"
    }
  ]
}
