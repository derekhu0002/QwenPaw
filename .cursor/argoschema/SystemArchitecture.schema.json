{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./.cursor/argoschema/SystemArchitecture.schema.json",
  "title": "SystemArchitecture Knowledge Graph Schema",
  "description": "Schema for design/KG/SystemArchitecture.json. The repository keeps its existing knowledge-graph shape, while ArchiMate 3.2 terminology is enforced for element and relationship concepts.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name",
    "description",
    "standard",
    "elements",
    "relationships",
    "views"
  ],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "standard": {
      "$ref": "#/$defs/standard"
    },
    "attributes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/attribute"
      }
    },
    "elements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/element"
      }
    },
    "relationships": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/relationship"
      }
    },
    "views": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/view"
      }
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "standard": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "version"
      ],
      "properties": {
        "name": {
          "const": "ArchiMate"
        },
        "version": {
          "const": "3.2"
        },
        "profile": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    },
    "archimateElementType": {
      "type": "string",
      "enum": [
        "Resource",
        "Capability",
        "Value Stream",
        "Course of Action",
        "Business Actor",
        "Business Role",
        "Business Collaboration",
        "Business Interface",
        "Business Process",
        "Business Function",
        "Business Interaction",
        "Business Event",
        "Business Service",
        "Business Object",
        "Contract",
        "Representation",
        "Product",
        "Application Component",
        "Application Collaboration",
        "Application Interface",
        "Application Process",
        "Application Function",
        "Application Interaction",
        "Application Event",
        "Application Service",
        "Data Object",
        "Node",
        "Device",
        "System Software",
        "Technology Collaboration",
        "Technology Interface",
        "Path",
        "Communication Network",
        "Technology Process",
        "Technology Function",
        "Technology Interaction",
        "Technology Event",
        "Technology Service",
        "Artifact",
        "Equipment",
        "Facility",
        "Distribution Network",
        "Material",
        "Stakeholder",
        "Driver",
        "Assessment",
        "Goal",
        "Outcome",
        "Principle",
        "Requirement",
        "Constraint",
        "Meaning",
        "Value",
        "Work Package",
        "Deliverable",
        "Implementation Event",
        "Plateau",
        "Gap",
        "Grouping",
        "Location",
        "Junction",
        "And Junction",
        "Or Junction"
      ]
    },
    "archimateLayer": {
      "type": "string",
      "enum": [
        "Strategy",
        "Business",
        "Application",
        "Technology",
        "Physical",
        "Motivation",
        "Implementation & Migration",
        "Other"
      ]
    },
    "archimateAspect": {
      "type": "string",
      "enum": [
        "Strategy",
        "Active Structure",
        "Behavior",
        "Passive Structure",
        "Composite",
        "Motivation",
        "Implementation & Migration",
        "Other"
      ]
    },
    "archimateRelationshipType": {
      "type": "string",
      "enum": [
        "Association",
        "Composition",
        "Aggregation",
        "Assignment",
        "Realization",
        "Serving",
        "Access",
        "Influence",
        "Triggering",
        "Flow",
        "Specialization"
      ]
    },
    "archimateRelationshipCategory": {
      "type": "string",
      "enum": [
        "Structural",
        "Dependency",
        "Dynamic",
        "Other"
      ]
    },
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "type": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "start_date": {
          "type": "string"
        },
        "completion_date": {
          "type": "string"
        },
        "due_date": {
          "type": "string"
        },
        "reporter": {
          "type": "string"
        },
        "priority": {
          "type": "string"
        },
        "assigned_to": {
          "type": "string"
        },
        "progress": {
          "type": "string"
        }
      }
    },
    "resource": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "owner",
        "role",
        "start_date",
        "end_date",
        "percent_complete",
        "expected_hours"
      ],
      "properties": {
        "owner": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "role": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "description": {
          "type": "string"
        },
        "start_date": {
          "type": "string"
        },
        "end_date": {
          "type": "string"
        },
        "percent_complete": {
          "type": "number"
        },
        "expected_hours": {
          "type": "number"
        },
        "history": {
          "type": "string"
        }
      }
    },
    "projectSummary": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "notes": {
          "type": "string"
        },
        "started": {
          "type": "string"
        },
        "deadline": {
          "type": "string"
        },
        "priority": {
          "type": "string"
        },
        "assigned_to": {
          "type": "string"
        },
        "progress": {
          "type": "string"
        }
      }
    },
    "projectInfo": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "summary": {
          "$ref": "#/$defs/projectSummary"
        },
        "resources": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/resource"
          }
        },
        "tasks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/task"
          }
        }
      }
    },
    "attribute": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name"
      ],
      "description": "Generic EA-style attribute container. Use this for architecture annotations such as verification_focus, external_scope, acceptance_outcomes, and design_risks instead of introducing dedicated top-level fields.",
      "properties": {
        "name": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "description": {
          "type": "string"
        },
        "value": {
          "type": "string"
        },
        "content": {
          "type": "string"
        }
      }
    },
    "subdiagramView": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "view_id",
        "view_name"
      ],
      "properties": {
        "view_id": {
          "$ref": "#/$defs/identifier"
        },
        "view_name": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    },
    "testcase": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "description",
        "type",
        "Input",
        "acceptanceCriteria",
        "TestResults"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/nonEmptyString",
          "description": "Stable testcase identifier. Use the testcase name itself as the long-lived identity; do not add a separate testcase id field."
        },
        "description": {
          "$ref": "#/$defs/nonEmptyString",
          "description": "Place the intent being verified here. Each testcase should normally be mounted under exactly one element rather than using extra verifies_elements or verifies_intents fields."
        },
        "type": {
          "type": "string",
          "enum": [
            "Unit Test",
            "Integration Test",
            "System Test",
            "Acceptance Test",
            "Scenario Test",
            "Inspection Test"
          ]
        },
        "Input": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "acceptanceCriteria": {
          "$ref": "#/$defs/nonEmptyString",
          "description": "By the end of implementation design, this must be the concrete workspace-relative executable testcase entrypoint for the testcase, optionally including a pytest node id selector such as tests/test_x.py::test_y, rather than descriptive prose."
        },
        "TestResults": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    },
    "element": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "type",
        "archimate_layer",
        "archimate_aspect"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/identifier"
        },
        "name": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "parent": {
          "$ref": "#/$defs/identifier"
        },
        "type": {
          "$ref": "#/$defs/archimateElementType"
        },
        "archimate_layer": {
          "$ref": "#/$defs/archimateLayer"
        },
        "archimate_aspect": {
          "$ref": "#/$defs/archimateAspect"
        },
        "alias": {
          "type": "string"
        },
        "classifier": {
          "type": "string"
        },
        "browser_path": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "document": {
          "type": "string"
        },
        "attributes": {
          "type": "array",
          "description": "Use attributes to store additional architecture intent metadata, including verification_focus, external_scope, acceptance_outcomes, and design_risks.",
          "items": {
            "$ref": "#/$defs/attribute"
          }
        },
        "code_file": {
          "type": "string"
        },
        "condition_file": {
          "type": "string"
        },
        "prompts_file": {
          "type": "string"
        },
        "project_info": {
          "$ref": "#/$defs/projectInfo"
        },
        "subdiagram_views": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/subdiagramView"
          }
        },
        "testcases": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/testcase"
          }
        }
      }
    },
    "relationshipAttribute": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "description"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "description": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    },
    "relationship": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "statement",
        "name",
        "archimate_category",
        "source_id",
        "target_id",
        "source_name",
        "target_name"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/identifier"
        },
        "statement": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "name": {
          "$ref": "#/$defs/archimateRelationshipType"
        },
        "archimate_category": {
          "$ref": "#/$defs/archimateRelationshipCategory"
        },
        "description": {
          "type": "string"
        },
        "sequence": {
          "type": "string"
        },
        "super_type": {
          "type": "string"
        },
        "document": {
          "type": "string"
        },
        "attributes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/relationshipAttribute"
          }
        },
        "source_id": {
          "$ref": "#/$defs/identifier"
        },
        "target_id": {
          "$ref": "#/$defs/identifier"
        },
        "source_name": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "target_name": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    },
    "view": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "view_id",
        "view_name",
        "included_elements",
        "included_relationships"
      ],
      "properties": {
        "view_id": {
          "$ref": "#/$defs/identifier"
        },
        "view_name": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "browser_path": {
          "type": "string"
        },
        "parent_element_id": {
          "$ref": "#/$defs/identifier"
        },
        "parent_element_name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "included_elements": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/identifier"
          }
        },
        "included_relationships": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/identifier"
          }
        }
      }
    }
  }
}
